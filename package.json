{
  "name": "ngocky",
  "version": "1.1.0",
  "private": true,
  "description": "NgocKy – Family Productivity App",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "pm2:logs": "pm2 logs ngocky-api ngocky-web",
    "pm2:stop": "pm2 stop ngocky-api ngocky-web",
    "pm2:delete": "pm2 delete ngocky-api ngocky-web",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:generate": "npm run db:generate -w apps/api",
    "lint": "npm run lint -w apps/api && npm run lint -w apps/web"
  }
}
