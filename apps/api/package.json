{
    "name": "@ngocky/api",
    "version": "1.1.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc || true",
        "start": "node dist/index.js",
        "db:migrate": "prisma migrate deploy",
        "db:migrate:dev": "prisma migrate dev",
        "db:seed": "tsx prisma/seed.ts",
