        "lint": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@prisma/client": "^6.4.1",
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "openai": "^6.27.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^2.1.0",
        "@types/node": "^22.13.5",
        "@types/supertest": "^7.2.0",
        "prisma": "^6.4.1",
        "supertest": "^7.2.2",
        "tsx": "^4.19.3",
        "typescript": "^5.7.3",
        "vitest": "^4.0.18"
