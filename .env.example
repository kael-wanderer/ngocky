# ─── App ────────────────────────────────────────
APP_PORT=3001
APP_VERSION=1.0.0
NODE_ENV=development

# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql://ngocky:ngocky_secret@localhost:5432/ngocky?schema=public

# ─── JWT ────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Owner Seed ─────────────────────────────────
OWNER_NAME=Owner
OWNER_EMAIL=owner@ngocky.local
OWNER_PASSWORD=ChangeMe123!

# ─── Frontend ───────────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ─── CORS ───────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Chat Assistant ──────────────────────────────
# Shared secret between n8n and the assistant API routes (min 16 chars)
ASSISTANT_API_KEY=change-me-to-a-random-secret-at-least-32-chars
# Anthropic API key for LLM intent parsing (required for Phase 5 Option B)
# ANTHROPIC_API_KEY=sk-ant-...
